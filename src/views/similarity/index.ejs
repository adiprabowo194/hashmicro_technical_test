<%- include('../layouts/header') %>
    <%- include('../layouts/navbar') %>
        <div class="container my-5">
            <div class="row justify-content-center">
                <div class="col-12 col-lg-9">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-primary text-white p-3">
                            <h4 class="card-title m-0 fw-bold fs-5">Similarity Checker</h4>
                        </div>
                        <div class="card-body p-4">
                            <form action="/similarity" method="POST">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold text-secondary">Text 1 (Base
                                            String)</label>
                                        <textarea name="text1" rows="5" class="form-control" placeholder="e.g. ABBCD"
                                            required><%= text1 %></textarea>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold text-secondary">Text 2 (Target
                                            String)</label>
                                        <textarea name="text2" rows="5" class="form-control"
                                            placeholder="e.g. Gallant Duck" required><%= text2 %></textarea>
                                    </div>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-semibold text-secondary d-block">Calculation
                                        Type</label>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="type" id="typeNonSensitive"
                                            value="non sensitive" <%=type==='non sensitive' || !type ? 'checked' : ''
                                            %>>
                                        <label class="form-check-label" role="button" for="typeNonSensitive">Non-Case
                                            Sensitive (A = a)</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="type" id="typeSensitive"
                                            value="sensitive" <%=type==='sensitive' ? 'checked' : '' %>>
                                        <label class="form-check-label" role="button" for="typeSensitive">Case Sensitive
                                            (A &ne; a)</label>
                                    </div>
                                </div>
                                <div class="d-flex justify-content-between align-items-center border-top pt-3">
                                    <span class="text-muted small">* Formula based on unique characters of Text 1 inside
                                        Text 2</span>
                                    <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">Compare
                                        Texts</button>
                                </div>
                            </form>
                            <% if (score !==null) { %>
                                <div class="alert alert-success d-flex align-items-center mt-4 border-0 shadow-sm"
                                    role="alert">
                                    <div class="flex-grow-1">
                                        <span class="fs-6">Similarity Score Result:</span>
                                        <h3 class="alert-heading fw-bold m-0 mt-1 text-success">
                                            <%= score %>%
                                        </h3>
                                    </div>
                                    <span class="badge bg-success px-3 py-2 text-capitalize">
                                        <%= type %>
                                    </span>
                                </div>
                                <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <%- include('../layouts/footer') %>