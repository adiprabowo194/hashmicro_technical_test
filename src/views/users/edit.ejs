<%- include('../layouts/header') %>
    <%- include('../layouts/navbar') %>
        <div class="container my-5">
            <div class="row justify-content-center">
                <div class="col-12 col-md-10 col-lg-7">
                    <div class="mb-3">
                        <a href="/users" class="btn btn-sm btn-outline-secondary px-3">
                            &larr; Back to List
                        </a>
                    </div>
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-warning text-dark p-3">
                            <h4 class="card-title m-0 fw-bold fs-5">Edit User Profile</h4>
                        </div>
                        <div class="card-body p-4">
                            <form action="/users/update/<%= targetUser._id %>?_method=PUT" method="POST">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold text-secondary">Full Name</label>
                                        <input type="text" name="name" class="form-control"
                                            value="<%= targetUser.name %>" required>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold text-secondary">Email Address</label>
                                        <input type="email" name="email" class="form-control"
                                            value="<%= targetUser.email %>" required>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold text-secondary">Phone</label>
                                        <input type="text" name="phone" class="form-control"
                                            value="<%= targetUser.phone || '' %>" placeholder="e.g. 08123456789">
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold text-secondary">Age</label>
                                        <input type="number" name="age" class="form-control"
                                            value="<%= targetUser.age || '' %>" placeholder="e.g. 25">
                                    </div>
                                </div>
                                <hr class="text-muted my-3">
                                <div class="row">
                                    <div class="col-12 mb-3">
                                        <label class="form-label fw-semibold text-secondary">Department</label>
                                        <input type="text" name="department" class="form-control"
                                            value="<%= targetUser.department || '' %>"
                                            placeholder="e.g. IT, HR, Finance">
                                    </div>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-semibold text-secondary">Salary (IDR)</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light fw-medium">Rp</span>
                                        <input type="number" name="salary" class="form-control"
                                            value="<%= targetUser.salary || '' %>" placeholder="e.g. 7500000">
                                    </div>
                                </div>
                                <div class="d-flex justify-content-end gap-2 pt-2">
                                    <a href="/users" class="btn btn-light px-4 border">Cancel</a>
                                    <button type="submit"
                                        class="btn btn-warning px-4 fw-bold shadow-sm text-dark">Update User</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <%- include('../layouts/footer') %>