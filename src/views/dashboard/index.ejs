<%- include('../layouts/header') %>
    <%- include('../layouts/navbar') %>
        <div class="container my-4">
            <div class="row mb-4">
                <div class="col-12">
                    <h3 class="fw-bold text-secondary text-capitalize">
                        Welcome, <%= greeting %>
                    </h3>
                </div>
            </div>
            <div class="row g-3">
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card text-bg-primary border-0 shadow-sm">
                        <div class="card-body p-4">
                            <h5 class="card-title opacity-75 fw-medium mb-2">Total User</h5>
                            <h2 class="display-6 fw-bold m-0">
                                <a href="users" class="text-reset text-decoration-none">
                                    <%= totalUsers %>
                                </a>
                            </h2>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card text-bg-warning border-0 shadow-sm">
                        <div class="card-body p-4">
                            <h5 class="card-title opacity-75 fw-medium mb-2">Average Salary</h5>
                            <h2 class="display-6 fw-bold m-0">
                                <%= typeof averageSalary==='number' ? 'Rp ' + averageSalary.toLocaleString('id-ID')
                                    : 'Rp ' + averageSalary %>
                            </h2>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card text-bg-success border-0 shadow-sm">
                        <div class="card-body p-4">
                            <h5 class="card-title opacity-75 fw-medium mb-2">Highest Salary</h5>
                            <h2 class="display-6 fw-bold m-0">
                                <%= typeof highestSalary==='number' ? 'Rp ' + highestSalary.toLocaleString('id-ID')
                                    : 'Rp ' + highestSalary %>
                            </h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <%- include('../layouts/footer') %>